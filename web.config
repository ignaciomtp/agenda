<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>

    <!-- 🔒 1️⃣ Bloquear acceso a carpetas internas -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment="src" />
          <add segment="logs" />
          <add segment="partials" />
          <add segment="scripts" />
          <add segment="vendor" />
          <add segment=".vscode" />
        </hiddenSegments>
      </requestFiltering>
    </security>

    <!-- 🚫 2️⃣ Bloquear tipos de archivos sensibles -->
    <staticContent>
      <remove fileExtension=".ini" />
      <remove fileExtension=".env" />
      <remove fileExtension=".log" />
      <remove fileExtension=".txt" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".ini" mimeType="text/plain" />
      <mimeMap fileExtension=".env" mimeType="text/plain" />
      <mimeMap fileExtension=".log" mimeType="text/plain" />
      <mimeMap fileExtension=".txt" mimeType="text/plain" />
      <mimeMap fileExtension=".json" mimeType="text/plain" />
    </staticContent>

    <handlers>
      <!-- Esto impide que IIS sirva directamente esos archivos -->
      <add name="BlockSensitiveFiles" path="*.ini" verb="*" modules="IsapiModule" scriptProcessor="" resourceType="File" requireAccess="None" />
      <add name="BlockEnvFiles" path="*.env" verb="*" modules="IsapiModule" scriptProcessor="" resourceType="File" requireAccess="None" />
      <add name="BlockLogs" path="*.log" verb="*" modules="IsapiModule" scriptProcessor="" resourceType="File" requireAccess="None" />
      <add name="BlockTxt" path="*.txt" verb="*" modules="IsapiModule" scriptProcessor="" resourceType="File" requireAccess="None" />
      <add name="BlockJson" path="*.json" verb="*" modules="IsapiModule" scriptProcessor="" resourceType="File" requireAccess="None" />
    </handlers>

    <!-- 🔄 3️⃣ Redirigir acceso directo a /agenda hacia /agenda/public/ -->
    <rewrite>
      <rules>
        <!-- Solo si la URL es exactamente /agenda o /agenda/ -->
        <rule name="RedirectToPublic" stopProcessing="true">
          <match url="^$" />
          <action type="Redirect" url="/agenda/public/" redirectType="Permanent" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>
</configuration>
